{
  "manifest_version": 3,
  "name": "Indeed Job Application Optimizer",
  "version": "1.2.0",
  "description": "Scrapes Indeed job listings and optimizes your resume and cover letter using AI.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.indeed.com/*",
    "http://localhost:3001/*",
    "https://*.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.indeed.com/*"
      ],
      "js": ["config.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
